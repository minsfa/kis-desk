# KIS Developers 키 템플릿 — 복사해서 config/.env 로 저장 후 채우기 (실제 .env는 git 제외)
# 발급: https://apiportal.koreainvestment.com

# === 실행 환경 (vts=모의, prod=실전). 기본 vts 권장 ===
KIS_ENV=vts

# === 모의투자 (openapivts) ===
KIS_VTS_APP_KEY=
KIS_VTS_APP_SECRET=
KIS_VTS_ACCOUNT=          # 계좌번호 앞 8자리
KIS_VTS_ACCOUNT_PROD=01   # 상품코드 뒤 2자리 (보통 01)

# === 실전투자 (openapi) ===
KIS_PROD_APP_KEY=
KIS_PROD_APP_SECRET=
KIS_PROD_ACCOUNT=
KIS_PROD_ACCOUNT_PROD=01

# === 안전 한도 (Phase 1에서 settings.yaml로 옮길 수 있음) ===
MAX_ORDER_AMOUNT=100000   # 1회 주문 최대 금액(원)
MAX_DAILY_TRADES=5        # 일일 최대 매매 횟수
DRY_RUN=true              # true면 실주문 대신 출력만

# === DART 전자공시 (무료) — opendart.fss.or.kr 에서 인증키 발급 ===
DART_API_KEY=

# === 네이버 검색 API (뉴스) — developers.naver.com ===
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
